---
const { lang = 'en' } = Astro.props;
const isEN = lang === 'en';

const cta1 = isEN ? 'Constitution' : 'Dastuurka';
const cta2 = isEN ? 'Download PDF' : 'Download PDF';
const pdfHref = isEN ? '/Somalia-Constitution2012.pdf' : '/Dastuurka-KMG-2012.pdf';
const supportingText = isEN
  ? ''
  : '';

---

<section class="relative isolate overflow-hidden bg-gradient-to-b from-sky-50/80 via-white to-white dark:bg-slate-950">
  <div class="pointer-events-none absolute inset-0 -z-10 hidden bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] dark:block dark:from-slate-900 dark:to-slate-950" aria-hidden="true"></div>
  <!-- Light mode: soft glow blobs only -->
  <div class="absolute -left-24 -top-20 -z-10 h-72 w-72 rounded-full bg-sky-300/30 blur-3xl dark:hidden"></div>
  <div class="absolute left-[30%] -top-10 -z-10 h-56 w-96 rounded-full bg-cyan-200/25 blur-3xl dark:hidden"></div>
  <div class="absolute right-[10%] top-[10%] -z-10 h-80 w-80 rounded-full bg-sky-200/35 blur-3xl dark:hidden"></div>

  <!-- Subtle decorative legal/digital/national icon texture -->
  <div class="pointer-events-none absolute inset-0 z-0 hidden md:block" aria-hidden="true">
    <!-- Somali star -->
    <div class="absolute left-6 top-16 text-slate-400/25 dark:text-slate-400/15">
      <svg viewBox="0 0 100 100" class="h-10 w-10 lg:h-14 lg:w-14" fill="none" xmlns="http://www.w3.org/2000/svg">
        <polygon points="50,8 61,38 93,38 67,57 77,89 50,70 23,89 33,57 7,38 39,38" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
      </svg>
    </div>

    <!-- Open law book / document -->
    <div class="absolute left-10 bottom-16 text-slate-400/25 dark:text-slate-400/15">
      <svg viewBox="0 0 120 90" class="h-12 w-16 lg:h-16 lg:w-24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M10 70V24c0-6 4-10 10-10h34c9 0 16 3 22 9v47c-6-6-13-9-22-9H20c-6 0-10 4-10 9z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
        <path d="M110 70V24c0-6-4-10-10-10H66c-9 0-16 3-22 9v47c6-6 13-9 22-9h34c6 0 10 4 10 9z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
        <line x1="60" y1="24" x2="60" y2="70" stroke="currentColor" stroke-width="2"/>
      </svg>
    </div>

    <!-- Balance scale -->
    <div class="absolute right-8 top-14 text-slate-400/25 dark:text-slate-400/15 xl:right-16">
      <svg viewBox="0 0 80 96" class="h-12 w-10 lg:h-16 lg:w-14" fill="none" xmlns="http://www.w3.org/2000/svg">
        <line x1="40" y1="12" x2="40" y2="74" stroke="currentColor" stroke-width="2"/>
        <line x1="16" y1="30" x2="64" y2="30" stroke="currentColor" stroke-width="2"/>
        <path d="M10 30l10 18H0L10 30z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
        <path d="M70 30l10 18H60L70 30z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
        <line x1="24" y1="30" x2="10" y2="30" stroke="currentColor" stroke-width="2"/>
        <line x1="56" y1="30" x2="70" y2="30" stroke="currentColor" stroke-width="2"/>
        <rect x="22" y="74" width="36" height="8" rx="2" stroke="currentColor" stroke-width="2"/>
      </svg>
    </div>

    <!-- Search over document -->
    <div class="absolute right-6 bottom-10 text-slate-400/25 dark:text-slate-400/15 xl:right-12">
      <svg viewBox="0 0 110 90" class="h-12 w-16 lg:h-16 lg:w-24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="8" y="10" width="62" height="70" rx="6" stroke="currentColor" stroke-width="2"/>
        <line x1="20" y1="28" x2="56" y2="28" stroke="currentColor" stroke-width="2"/>
        <line x1="20" y1="40" x2="50" y2="40" stroke="currentColor" stroke-width="2"/>
        <line x1="20" y1="52" x2="44" y2="52" stroke="currentColor" stroke-width="2"/>
        <circle cx="74" cy="58" r="14" stroke="currentColor" stroke-width="2"/>
        <line x1="84" y1="68" x2="102" y2="86" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </div>
  </div>

  <div class="mx-auto max-w-[90rem] px-4 py-16 sm:px-6 sm:py-24 lg:px-8 lg:py-28">
    <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
      <!-- Left: Content -->
      <div class="order-2 mx-auto max-w-2xl text-center lg:order-1 lg:mx-0 lg:text-left">
        {isEN ? (
          <>
            <h1 class="whitespace-nowrap text-3xl font-extrabold leading-none tracking-tight sm:text-5xl lg:text-6xl">
              <span class="bg-gradient-to-r from-slate-700 via-sky-700 to-sky-500 bg-clip-text text-transparent dark:from-slate-200 dark:via-sky-300 dark:to-sky-400">
                Provisional Constitution
              </span>
            </h1>
            <p class="mt-5 text-lg font-medium leading-tight tracking-tight text-sky-700 sm:text-2xl lg:text-4xl dark:text-slate-200">
              The Federal Republic of Somalia
            </p>
          </>
        ) : (
          <>
            <h1 class="text-5xl font-extrabold leading-none tracking-tight sm:text-6xl lg:text-7xl">
              <span class="bg-gradient-to-r from-slate-700 via-sky-700 to-sky-500 bg-clip-text text-transparent dark:from-slate-200 dark:via-sky-300 dark:to-sky-400">
                Dastuurka
              </span>
            </h1>
            <p class="mt-5 text-lg font-medium leading-tight tracking-tight text-sky-700 sm:text-2xl lg:text-3xl dark:text-slate-200">
              Jamhuuriyadda Federaalka ee Soomaaliya
            </p>
          </>
        )}

        {supportingText && (
          <p class="mt-8 max-w-2xl text-base leading-7 text-zinc-600 sm:text-lg dark:text-slate-400">
            {supportingText}
          </p>
        )}

        <div class="mt-12 flex flex-row flex-wrap items-center justify-center gap-3 lg:justify-start">
          <a
            href={`/${lang}#chapters`}
            class="inline-flex items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-sky-800 to-sky-700 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-sky-900/25 transition hover:from-sky-900 hover:to-sky-800"
          >
            {cta1}
            <span aria-hidden="true">→</span>
          </a>
          <a
            href={pdfHref}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center rounded-xl border border-zinc-300/90 bg-white/90 px-6 py-3 text-sm font-semibold text-zinc-700 shadow-sm transition hover:border-zinc-400 hover:bg-zinc-50 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200 dark:hover:bg-slate-800"
          >
            {cta2}
          </a>
        </div>

        <p class="my-5 text-sm italic text-zinc-500 dark:text-slate-400">
          {isEN ? 'Adopted August 1, 2012 Mogadishu, Somalia' : 'La Ansixiyey August 1, 2012 Muqdishu, Soomaaliya'}
        </p>

        <ul class="mt-10 flex flex-nowrap justify-center gap-1.5 text-xs text-zinc-600 dark:text-slate-400 sm:gap-2.5 sm:text-sm lg:justify-start">
          <li class="inline-flex items-center whitespace-nowrap rounded-full border border-zinc-200/90 bg-white/90 px-2 py-1 shadow-sm sm:px-3 sm:py-1.5 dark:border-slate-700 dark:bg-slate-900">
            <span>15 Chapters</span>
          </li>
          <li class="inline-flex items-center whitespace-nowrap rounded-full border border-zinc-200/90 bg-white/90 px-2 py-1 shadow-sm sm:px-3 sm:py-1.5 dark:border-slate-700 dark:bg-slate-900">
            <span>143 Articles</span>
          </li>
          <li class="inline-flex items-center whitespace-nowrap rounded-full border border-zinc-200/90 bg-white/90 px-2 py-1 shadow-sm sm:px-3 sm:py-1.5 dark:border-slate-700 dark:bg-slate-900">
            <span>Somali & English</span>
          </li>
        </ul>
      </div>

      <!-- Right: Visual -->
      <div class="order-1 flex items-center justify-center lg:order-2 lg:justify-end">
        <div class="relative flex items-center justify-center">
          <!-- Emblem glow — dark mode only -->
          <div class="pointer-events-none absolute hidden h-[300px] w-[300px] rounded-full bg-blue-500/10 blur-3xl dark:block" aria-hidden="true"></div>
          <img
            src="/somalia-emblem.svg"
            alt="Somali coat of arms"
            class="relative h-[230px] w-auto opacity-95 sm:h-[300px] lg:h-[410px]"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </div>
</section>

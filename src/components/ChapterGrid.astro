---
import type { Chapter, Lang } from '../lib/data';
const { lang = 'en', chapters = [] as Chapter[], showAbout = false } = Astro.props;

function pick(obj: any, lang: Lang) {
  return obj?.[lang] ?? obj?.en ?? obj?.so ?? '';
}

// Calculate starting article number for each chapter
function getArticleRange(chapterIndex: number, chapters: Chapter[]) {
  let startArticle = 1;
  for (let i = 0; i < chapterIndex; i++) {
    startArticle += chapters[i].articleCount;
  }
  const endArticle = startArticle + chapters[chapterIndex].articleCount - 1;
  return { startArticle, endArticle };
}
---

<section id="chapters" class="py-16">
  <div class="w-full border-t border-zinc-200/70 bg-zinc-50 py-14 dark:border-zinc-700/70 dark:bg-zinc-800/40">
    <div class="mx-auto max-w-[90rem] px-4 sm:px-4 sm:px-6 lg:px-8">
      {showAbout && (
        <div class="mx-auto mb-10 max-w-4xl text-center">
          <h2 class="text-3xl font-extrabold tracking-tight text-zinc-900 dark:text-white sm:text-4xl">About this site</h2>
          <p class="mx-auto mt-4 max-w-3xl text-lg leading-8 text-zinc-600 dark:text-zinc-300">
            Making Somalia's Constitution accessible to everyone in a clean, readable, and modern format. Browse all 15 chapters and 143 articles, search instantly, and easily reference individual articles.
          </p>
          <div class="mx-auto mt-5 h-px w-24 bg-zinc-300/80 dark:bg-zinc-700/80"></div>
          <div class="mt-6 flex flex-wrap items-center justify-center gap-2 text-xs text-zinc-500 dark:text-zinc-400">
            <span class="rounded-full border border-zinc-200 bg-white px-3 py-1 dark:border-zinc-700 dark:bg-zinc-800">15 Chapters</span>
            <span class="rounded-full border border-zinc-200 bg-white px-3 py-1 dark:border-zinc-700 dark:bg-zinc-800">143 Articles</span>
            <span class="rounded-full border border-zinc-200 bg-white px-3 py-1 dark:border-zinc-700 dark:bg-zinc-800">Somali & English</span>
          </div>
        </div>
      )}

      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-sm font-semibold uppercase tracking-[0.14em] text-zinc-500 dark:text-zinc-400">
          {lang === 'en' ? 'Chapters' : 'Cutubyada'}
        </h2>
        <p class="mt-3 text-base leading-8 text-zinc-500 dark:text-zinc-400">
          {lang === 'en'
            ? 'Select a chapter to view its articles.'
            : 'Dooro cutubka aad rabto si aad u aragto qodobadiisa.'}
        </p>
        <div class="mx-auto mt-5 h-px w-24 bg-zinc-300/80 dark:bg-zinc-700/80"></div>
      </div>

      <div class={showAbout ? 'mt-8 grid gap-6 md:grid-cols-2 lg:grid-cols-3' : 'mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3'}>
        {chapters.map((c: Chapter, index: number) => {
          const { startArticle, endArticle } = getArticleRange(index, chapters);
          const articleRangeLabel = lang === 'en'
            ? `Articles ${startArticle} - ${endArticle}`
            : `Qodobka ${startArticle}aad - ${endArticle}aad`;

          return (
          <a
            href={`/${lang}/chapters/${c.slug}`}
            class="group rounded-sm border border-zinc-200 bg-white p-4 sm:p-6 md:p-8 shadow-sm ring-1 ring-zinc-900/5 hover:shadow-xl hover:ring-2 hover:ring-sky-500/50 hover:-translate-y-0.5 transition-all duration-200 dark:border-zinc-700 dark:bg-zinc-800 dark:ring-white/5 dark:hover:ring-sky-400/50"
          >
            <!-- top icon row -->
            <div>
            </div>

            <p class="mt-1 text-xs font-semibold uppercase tracking-wide text-zinc-400 dark:text-zinc-500">
              {lang === 'en' ? `Chapter ${c.number}` : `Cutubka ${c.number}aad`}
            </p>
            <h3 class="mt-2 text-xl font-bold tracking-tight leading-snug text-zinc-900 dark:text-white">
              {pick(c.title, lang)}
            </h3>
            <p class="mt-4 text-base leading-7 text-zinc-600 dark:text-zinc-300">
              {pick(c.description, lang)}
            </p>

            <div class="mt-6 border-t border-zinc-200/60 pt-4 dark:border-zinc-800/60">
              <div class="flex items-center justify-between text-sm text-zinc-500 dark:text-zinc-400">
                <div class="flex items-center gap-3">
                  <span class="inline-flex items-center gap-2 rounded-full bg-sky-50/70 px-3 py-1 text-xs font-semibold text-sky-700 ring-1 ring-sky-200/70 dark:bg-sky-500/10 dark:text-sky-300 dark:ring-sky-400/25">{articleRangeLabel}</span>
                </div>

                <span class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-zinc-200/80 bg-white text-zinc-500 group-hover:bg-sky-50 group-hover:text-sky-600 group-hover:border-sky-300 transition-all dark:border-zinc-700/80 dark:bg-zinc-800 dark:text-zinc-300 dark:group-hover:bg-sky-900/40 dark:group-hover:text-sky-400 dark:group-hover:border-sky-700/50">
                  <span aria-hidden="true">→</span>
                </span>
              </div>
            </div>
          </a>
          );
        })}
      </div>
    </div>
  </div>
</section>
